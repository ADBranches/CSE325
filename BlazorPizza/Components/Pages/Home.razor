@page "/"
@rendermode InteractiveServer

<PageTitle>Blazor Pizza</PageTitle>

<div class="pizza-page">
    <section class="pizza-menu" id="menu" aria-label="Pizza menu">
        @foreach (var pizza in Pizzas)
        {
            <article class="pizza-tile">
                <img src="@pizza.Image" alt="@($"{pizza.Name} pizza")" />

                <div class="pizza-overlay">
                    <h2>@pizza.Name</h2>
                    <p>@pizza.Description</p>
                </div>

                <button type="button" class="price-button" @onclick="() => AddPizza(pizza)">
                    @FormatCurrency(pizza.Price)
                </button>
            </article>
        }
    </section>

    <aside class="order-pane" id="order" aria-label="Current order">
        <div class="order-content">
            <h1>Your Order</h1>

            @if (OrderItems.Count == 0)
            {
                <div class="empty-order">
                    <strong>No pizzas selected yet.</strong>
                    <span>Choose a pizza from the menu to begin your order.</span>
                </div>
            }
            else
            {
                <div class="order-items">
                    @foreach (var item in OrderItems)
                    {
                        <div class="order-item">
                            <div>
                                <strong>@item.Pizza.Name</strong>
                                <span>@item.Quantity × @FormatCurrency(item.Pizza.Price)</span>
                            </div>

                            <button type="button" title="Remove item" @onclick="() => Decrease(item.Pizza)">
                                ×
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="order-footer">
            <div class="total-line">
                <span>Total:</span>
                <strong>@FormatCurrency(OrderTotal)</strong>
            </div>

            <button type="button" class="order-button" disabled="@(OrderItems.Count == 0)">
                Order &gt;
            </button>
        </div>
    </aside>
</div>

@code {
    private readonly List<Pizza> Pizzas =
    [
        new("Buffalo Chicken", "Spicy chicken, hot sauce, and bleu cheese.", 12750, "images/pizza-chicken.svg"),
        new("The Baconatorizor", "A smoky BBQ pizza loaded with beef and cheese.", 11990, "images/pizza-bbq.svg"),
        new("Veggie Delight", "Mushrooms, onions, tomatoes, olives, and sweet pepper.", 11500, "images/pizza-veggie.svg"),
        new("Mushroom Lovers", "Mushrooms, mozzarella, and rich tomato sauce.", 11000, "images/pizza-veggie.svg"),
        new("Classic Pepperoni", "The pizza you grew up with, but Blazing hot.", 10500, "images/pizza-bbq.svg"),
        new("Basic Cheese Pizza", "Cheesy, simple, and delicious.", 9990, "images/pizza-margherita.svg"),
        new("Margherita", "Traditional Italian pizza with tomatoes and basil.", 9990, "images/pizza-margherita.svg")
    ];

    private readonly List<OrderItem> OrderItems = [];

    private decimal OrderTotal => OrderItems.Sum(item => item.Pizza.Price * item.Quantity);

    private static string FormatCurrency(decimal amount) => $"UGX {amount:N0}";

    private void AddPizza(Pizza pizza)
    {
        var existingItem = OrderItems.FirstOrDefault(item => item.Pizza.Name == pizza.Name);

        if (existingItem is null)
        {
            OrderItems.Add(new OrderItem(pizza, 1));
        }
        else
        {
            existingItem.Quantity++;
        }
    }

    private void Decrease(Pizza pizza)
    {
        var existingItem = OrderItems.FirstOrDefault(item => item.Pizza.Name == pizza.Name);

        if (existingItem is null)
        {
            return;
        }

        existingItem.Quantity--;

        if (existingItem.Quantity <= 0)
        {
            OrderItems.Remove(existingItem);
        }
    }

    private sealed record Pizza(string Name, string Description, decimal Price, string Image);

    private sealed class OrderItem(Pizza pizza, int quantity)
    {
        public Pizza Pizza { get; } = pizza;

        public int Quantity { get; set; } = quantity;
    }
}
