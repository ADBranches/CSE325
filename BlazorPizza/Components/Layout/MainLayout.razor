@inherits LayoutComponentBase

<div class="page-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <section class="main-wrapper">
        <header class="top-row">
            <a href="https://learn.microsoft.com/training/paths/build-web-apps-with-blazor/" target="_blank" rel="noopener noreferrer">
                Microsoft Blazor Learning Path
            </a>
        </header>

        <main class="content">
            @Body
        </main>

        <footer class="app-footer">
            <div>
                <strong>Edwin Pizza App</strong>
                <span>Fresh Blazor-built pizza ordering experience.</span>
            </div>
            <div>
                Edwin Kambale — Uganda
            </div>
        </footer>
    </section>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
